# 복사해서 .env.local 로 저장한 뒤 값을 채우세요. (.env.local 은 git에 올라가지 않음)
# 로컬에서 /api/* 서버리스를 쓰려면: npx vercel dev

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SESSION_SECRET=

# 이메일 인증 (Resend) — https://resend.com/api-keys
RESEND_API_KEY=
# 발신 주소: 도메인 인증 전에는 Resend 기본값 onboarding@resend.dev (테스트 수신만 가능)
# 운영: Resend에서 도메인 추가·DNS 인증 후 본인 도메인 주소 사용
EMAIL_FROM=onboarding@resend.dev

# 선택: SMS(NCP), Slack 알림 등
# SLACK_WEBHOOK_URL=
